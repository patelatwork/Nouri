# ── Database ──
POSTGRES_USER=nouri
POSTGRES_PASSWORD=nouri_secret_change_me
POSTGRES_DB=nouri_db
DATABASE_URL=postgresql+asyncpg://nouri:nouri_secret_change_me@db:5432/nouri_db

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── JWT ──
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Hugging Face ──
HUGGINGFACE_API_KEY=hf_your_api_key_here

# ── YouTube Data API v3 ──
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Pexels ──
PEXELS_API_KEY=your_pexels_api_key_here

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Nouri
